*.ipynb_checkpoints

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Datos crudos (el archivo grande sin comprimir no se versiona; sí su .gz y el archivo de test manual, chico)
data/raw/training.1600000.processed.noemoticon.csv

# Datos procesados (regenerables desde 01_preprocesamiento.ipynb)
# train_processed.csv sin comprimir pesa ~240MB, supera el límite de GitHub -> se versiona como train_processed.csv.gz (78MB, no ignorado por este patrón)
data/processed/*.csv
# topicos_train.csv es un objeto entregable chico (tabla de tópicos de 05_topicos_temporales.ipynb) -> sí se versiona
!data/processed/topicos_train.csv
# test_manual_processed.csv es chico (59KB) -- mismo criterio que train_processed.csv.gz, se versiona por conveniencia
!data/processed/test_manual_processed.csv
# comparacion_enfoques*.csv son la tabla de resultados final (entregable), no datos intermedios -- se versionan
!data/processed/comparacion_enfoques.csv
!data/processed/comparacion_enfoques_final.csv

# Modelos entrenados (pesados, no se versionan)
models/*.model
models/*.bin
models/*.p
models/*.pkl
# Cache de embeddings del corpus completo (~2.5GB, regenerable desde 05_topicos_temporales.ipynb)
models/*.npy

# IDEs
.idea/
.vscode/
*.swp
*.swo

# Logs y temporales
*.log
tmp/
